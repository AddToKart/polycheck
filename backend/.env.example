NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://polycheck:change-me@localhost:5432/polycheck?schema=public
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=15m
JWT_ISSUER=polycheck-api
JWT_AUDIENCE=polycheck-clients
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=false
ENABLE_API_DOCS=true
UPLOAD_DIR=uploads
MAX_PROOF_BYTES=5000000

# Seed tooling only; never reuse this value in production.
SEED_PASSWORD=replace-with-a-unique-12-character-password
ALLOW_PRODUCTION_SEED=false
