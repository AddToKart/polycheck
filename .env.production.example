POSTGRES_PASSWORD=replace-with-a-long-random-password
BETTER_AUTH_SECRET=replace-with-a-separate-32-byte-random-secret
BETTER_AUTH_URL=https://api.polycheck.example.edu
CORS_ORIGINS=https://polycheck.example.edu
FRONTEND_URL=https://polycheck.example.edu
NEXT_PUBLIC_API_URL=https://api.polycheck.example.edu/api
TRUST_PROXY=true
ENABLE_API_DOCS=false
MAX_PROOF_BYTES=5000000
STORAGE_DRIVER=s3
S3_BUCKET=polycheck-proofs
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.example.edu
S3_ACCESS_KEY_ID=replace-with-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-storage-secret-key
S3_FORCE_PATH_STYLE=true
BACKEND_PORT=4000
FRONTEND_PORT=3000
