generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  teacher
  student
}

enum DayOfWeek {
  Mon
  Tue
  Wed
  Thu
  Fri
  Sat
  Sun
}

enum AttendanceStatus {
  present
  late
  absent
  pending
  disputed
}

enum SectionRoleType {
  president
  qac
}

model User {
  id                String   @id @default(cuid())
  studentId         String?  @unique
  fullName          String
  email             String?  @unique
  password          String
  authEmail         String   @unique
  authEmailVerified Boolean  @default(true)
  role              UserRole
  program           String?
  yearLevel         Int?
  department        String?
  photoUrl          String?
  scope             String?
  teacherPublicKey  String?
  isActive          Boolean  @default(true)
  authVersion       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sections           Section[]
  enrollments        Enrollment[]
  attendanceRecords  AttendanceRecord[]
  sectionRoles       SectionRole[]
  sessionPermissions SessionPermission[]
  proofsOfClass      ProofOfClass[]
  createdSubjects    Subject[]           @relation("SubjectCreator")
  scanAttempts       ScanAttempt[]
  authAccounts       AuthAccount[]
  authSessions       AuthSession[]

  @@index([role])
  @@index([studentId])
  @@index([email])
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model AuthSession {
  id         String   @id
  expiresAt  DateTime
  token      String   @unique
  createdAt  DateTime
  updatedAt  DateTime
  ipAddress  String?
  userAgent  String?
  userId     String
  generation Int      @default(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, generation])
  @@index([expiresAt])
}

model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@index([identifier])
  @@index([expiresAt])
}

model InstitutionSetting {
  key       String   @id
  value     String
  updatedBy String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  createdById String?
  createdBy   User?    @relation("SubjectCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections Section[]

  @@index([createdById])
}

model Section {
  id                   String    @id @default(cuid())
  subjectId            String
  subject              Subject   @relation(fields: [subjectId], references: [id])
  section              String
  room                 String
  semester             String
  teacherId            String
  teacher              User      @relation(fields: [teacherId], references: [id])
  enrollmentCode       String?   @unique
  enrollmentCodeExpiry DateTime?
  studentCount         Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  schedule           ScheduleDay[]
  enrollments        Enrollment[]
  sessions           Session[]
  sectionRoles       SectionRole[]
  sessionPermissions SessionPermission[]
  proofsOfClass      ProofOfClass[]
  attendanceRecords  AttendanceRecord[]

  @@unique([subjectId, section, semester, teacherId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([enrollmentCode])
}

model ScheduleDay {
  id        String    @id @default(cuid())
  sectionId String
  section   Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  day       DayOfWeek
  startTime String
  endTime   String
  room      String?

  @@index([sectionId])
}

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  student    User     @relation(fields: [studentId], references: [id])
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id])
  enrolledAt DateTime @default(now())

  @@unique([studentId, sectionId])
  @@index([sectionId])
  @@index([studentId])
}

model Session {
  id                   String    @id @default(cuid())
  sectionId            String
  section              Section   @relation(fields: [sectionId], references: [id])
  teacherId            String
  subjectName          String
  date                 String
  startTime            String
  endTime              String
  room                 String?
  qrValidityMinutes    Int
  gracePeriodMinutes   Int
  geofenceLatitude     Float
  geofenceLongitude    Float
  geofenceRadiusMeters Int
  isActive             Boolean   @default(false)
  endedAt              DateTime?
  qrToken              String?
  qrTokenExpiresAt     DateTime?
  qrGeneratedAt        DateTime?
  isRescheduled        Boolean   @default(false)
  rescheduledFromDate  String?
  originalScheduleTime String?
  originalRoom         String?
  createdAt            DateTime  @default(now())

  attendanceRecords AttendanceRecord[]
  scanAttempts      ScanAttempt[]
  proofsOfClass     ProofOfClass[]

  @@index([sectionId])
  @@index([teacherId])
  @@index([date])
  @@index([isActive])
  @@index([teacherId, date])
  @@index([sectionId, date])
}

model ScanAttempt {
  id                       String            @id @default(cuid())
  sessionId                String
  session                  Session           @relation(fields: [sessionId], references: [id])
  studentId                String
  student                  User              @relation(fields: [studentId], references: [id])
  clientAttemptId          String?
  timestamp                DateTime
  clientScannedAt          DateTime?
  receivedAt               DateTime          @default(now())
  locationCapturedAt       DateTime?
  latitude                 Float
  longitude                Float
  accuracyMeters           Float?
  mocked                   Boolean?
  inputChannel             String?
  deviceId                 String?
  offline                  Boolean?          @default(false)
  distanceMeters           Float?
  geofenceRadiusMeters     Int?
  riskSignals              Json?
  outcome                  String
  reason                   String?
  message                  String?
  tokenHash                String?
  createdAt                DateTime          @default(now())
  acceptedAttendanceRecord AttendanceRecord? @relation("AcceptedScanAttempt")

  @@unique([studentId, clientAttemptId])
  @@index([sessionId, timestamp])
  @@index([studentId, timestamp])
  @@index([receivedAt])
  @@index([createdAt])
  @@index([studentId, deviceId, receivedAt])
  @@index([deviceId])
}

model AttendanceRecord {
  id                    String           @id @default(cuid())
  sessionId             String
  session               Session          @relation(fields: [sessionId], references: [id])
  sectionId             String
  section               Section          @relation(fields: [sectionId], references: [id])
  studentId             String
  student               User             @relation(fields: [studentId], references: [id])
  studentName           String
  studentProgram        String?
  timestamp             DateTime
  status                AttendanceStatus
  latitude              Float
  longitude             Float
  deviceId              String?
  tokenSnapshot         String?
  isSynced              Boolean          @default(false)
  syncedAt              DateTime?
  disputeReason         String?
  disputeDescription    String?
  disputeResolved       Boolean          @default(false)
  manuallySet           Boolean          @default(false)
  notes                 String?
  acceptedScanAttemptId String?          @unique
  acceptedScanAttempt   ScanAttempt?     @relation("AcceptedScanAttempt", fields: [acceptedScanAttemptId], references: [id], onDelete: Restrict)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([sectionId])
  @@index([status])
  @@index([isSynced])
  @@index([sessionId, status])
  @@index([sectionId, status])
  @@index([studentId, sectionId, timestamp])
}

model SectionRole {
  id          String          @id @default(cuid())
  sectionId   String
  section     Section         @relation(fields: [sectionId], references: [id])
  studentId   String
  student     User            @relation(fields: [studentId], references: [id])
  studentName String
  role        SectionRoleType
  grantedBy   String
  grantedAt   DateTime        @default(now())

  @@unique([sectionId, studentId, role])
  @@index([sectionId])
  @@index([studentId])
}

model SessionPermission {
  id        String   @id @default(cuid())
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id])
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  grantedBy String
  grantedAt DateTime @default(now())
  expiresAt DateTime
  isActive  Boolean  @default(true)

  @@unique([sectionId, studentId])
  @@index([sectionId])
  @@index([studentId])
  @@index([isActive, expiresAt])
}

model ProofOfClass {
  id                    String   @id @default(cuid())
  sectionId             String
  section               Section  @relation(fields: [sectionId], references: [id])
  sessionId             String
  session               Session  @relation(fields: [sessionId], references: [id])
  uploadedBy            String
  student               User     @relation(fields: [uploadedBy], references: [id])
  uploadedByStudentName String
  photoUrl              String
  uploadedAt            DateTime @default(now())
  description           String?

  @@index([sessionId])
  @@index([sectionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorRole  String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}
