NODE_ENV=development
PORT=4000
# Local development connects directly. Production must target PgBouncer and
# add pgbouncer=true while retaining explicit connection_limit/pool_timeout.
DATABASE_URL=postgresql://polycheck:<URL_ENCODED_PASSWORD>@localhost:5432/polycheck?schema=public&connection_limit=10&pool_timeout=10
# Migrations must always target PostgreSQL directly, never PgBouncer.
DIRECT_DATABASE_URL=postgresql://polycheck:<URL_ENCODED_PASSWORD>@localhost:5432/polycheck?schema=public&connection_limit=2&pool_timeout=30
REDIS_URL=redis://localhost:6379/0
BETTER_AUTH_SECRET=replace-with-a-separate-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=false
TRUST_PROXY_HOPS=1
ENABLE_API_DOCS=true
# Required in production. Generate independently from authentication secrets.
METRICS_TOKEN=replace-with-a-separate-32-byte-random-token
UPLOAD_DIR=uploads
MAX_PROOF_BYTES=5000000
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Seed tooling only; never reuse this value in production.
SEED_PASSWORD=replace-with-a-unique-12-character-password
ALLOW_PRODUCTION_SEED=false
