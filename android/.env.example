# ── Polycheck Mobile API Configuration ──
#
# IMPORTANT: NestJS backend must be running on port 4000.
# Start it with: cd backend && pnpm start:dev
#
# Android emulator: 10.0.2.2 resolves to the host machine.
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api
#
# Physical device: Replace with your machine's LAN IP address.
#   Windows: run `ipconfig` and look for "IPv4 Address".
#   macOS/Linux: run `ifconfig` or `ip addr`.
# EXPO_PUBLIC_API_URL=http://192.168.1.100:4000/api
#
# QR fallbacks (image upload + manual entry). Disabled by default.
# EXPO_PUBLIC_ALLOW_QR_FALLBACKS=true
