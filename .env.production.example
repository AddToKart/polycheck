# Replace every placeholder. Keep the real file out of version control.
POSTGRES_PASSWORD=<LONG_RANDOM_DATABASE_PASSWORD>
REDIS_PASSWORD=<LONG_RANDOM_REDIS_PASSWORD>

# URL-encode passwords embedded in URLs. Runtime traffic uses PgBouncer in
# transaction mode; migrations bypass it and use a deliberately small pool.
DATABASE_URL=postgresql://polycheck:<URL_ENCODED_POSTGRES_PASSWORD>@pgbouncer:5432/polycheck?schema=public&pgbouncer=true&connection_limit=10&pool_timeout=10
DIRECT_DATABASE_URL=postgresql://polycheck:<URL_ENCODED_POSTGRES_PASSWORD>@postgres:5432/polycheck?schema=public&connection_limit=2&pool_timeout=30
REDIS_URL=redis://:<URL_ENCODED_REDIS_PASSWORD>@redis:6379/0

BETTER_AUTH_SECRET=<SEPARATE_RANDOM_SECRET_AT_LEAST_32_CHARACTERS>
METRICS_TOKEN=<SEPARATE_RANDOM_METRICS_TOKEN_AT_LEAST_32_CHARACTERS>
BETTER_AUTH_URL=https://polycheck.example.edu
CORS_ORIGINS=https://polycheck.example.edu
FRONTEND_URL=https://polycheck.example.edu
NEXT_PUBLIC_API_URL=/api
TRUST_PROXY=true
# Host TLS proxy -> nginx -> backend. The outer proxy must replace, not append,
# any client-supplied X-Forwarded-For header.
TRUST_PROXY_HOPS=2
ENABLE_API_DOCS=false
MAX_PROOF_BYTES=5000000

STORAGE_DRIVER=s3
S3_BUCKET=<S3_BUCKET_NAME>
S3_REGION=<S3_REGION>
S3_ENDPOINT=<OPTIONAL_S3_COMPATIBLE_ENDPOINT>
S3_ACCESS_KEY_ID=<S3_ACCESS_KEY_OR_EMPTY_FOR_WORKLOAD_IDENTITY>
S3_SECRET_ACCESS_KEY=<S3_SECRET_KEY_OR_EMPTY_FOR_WORKLOAD_IDENTITY>
S3_FORCE_PATH_STYLE=false

# nginx binds loopback by default so a host-level TLS proxy can own 443.
HTTP_BIND_ADDRESS=127.0.0.1
HTTP_PORT=8080
BACKEND_REPLICAS=3

# Pool sizes must be capacity-planned against PostgreSQL max_connections.
PGBOUNCER_MAX_CLIENT_CONN=2000
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_MIN_POOL_SIZE=10
PGBOUNCER_RESERVE_POOL_SIZE=10
PGBOUNCER_SERVER_IDLE_TIMEOUT=600

# Optional image overrides should be immutable registry tags or digests.
BACKEND_IMAGE=polycheck-backend:local
FRONTEND_IMAGE=polycheck-frontend:local

# Per-container Compose limits. Adjust from observed production usage.
POSTGRES_MEMORY_LIMIT=2g
POSTGRES_CPU_LIMIT=2.0
POSTGRES_SHM_SIZE=256mb
PGBOUNCER_MEMORY_LIMIT=256m
PGBOUNCER_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=1g
REDIS_CPU_LIMIT=1.0
REDIS_MAXMEMORY=768mb
MIGRATION_MEMORY_LIMIT=512m
MIGRATION_CPU_LIMIT=1.0
BACKEND_MEMORY_LIMIT=768m
BACKEND_CPU_LIMIT=1.0
FRONTEND_MEMORY_LIMIT=512m
FRONTEND_CPU_LIMIT=1.0
NGINX_MEMORY_LIMIT=256m
NGINX_CPU_LIMIT=1.0
PROMETHEUS_MEMORY_LIMIT=512m
PROMETHEUS_CPU_LIMIT=0.5
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_PORT=9090
